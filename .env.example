# PrüfPilot Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://pruefpilot:pruefpilot_dev@db:5432/pruefpilot
DATABASE_URL_SYNC=postgresql://pruefpilot:pruefpilot_dev@db:5432/pruefpilot

# JWT Auth
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# S3 Storage (Hetzner Object Storage)
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=pruefpilot-files

# Email (Postmark)
POSTMARK_API_KEY=your-postmark-key
FROM_EMAIL=noreply@pruefpilot.de

# App
APP_NAME=PrüfPilot
APP_ENV=development
APP_URL=http://localhost:5173
API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Sentry (Error Monitoring)
SENTRY_DSN=
