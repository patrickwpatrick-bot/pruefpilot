# PrüfPilot Backend — Environment Variables
# Kopiere diese Datei zu .env und fülle die Werte aus

APP_ENV=development
SECRET_KEY=change-me-in-production

DATABASE_URL=postgresql+asyncpg://pruefpilot:pruefpilot_dev@localhost:5432/pruefpilot
DATABASE_URL_SYNC=postgresql://pruefpilot:pruefpilot_dev@localhost:5432/pruefpilot

# Anthropic API Key — für KI-Unterweisungen
# Schlüssel erhältst du unter: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# E-Mail (Postmark)
POSTMARK_API_KEY=

# S3 Storage
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
